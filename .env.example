# 이 파일을 복사해서 .env 로 만들고 값을 채우세요: cp .env.example .env
# .env 는 git 에 절대 올리지 않습니다(.gitignore 에 포함됨).

# --- PostgreSQL ---
POSTGRES_DB=monitoring
POSTGRES_USER=monitoring
POSTGRES_PASSWORD=change-me-strong-password

# --- Backend ---
# HA 가 POST 할 때 헤더 X-API-Key 로 보낼 공유 키 (Phase 1). 랜덤 32자 이상 권장.
API_KEY=change-me-random-32char-string
LOG_LEVEL=INFO
